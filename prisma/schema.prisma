generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  googleId      String    @unique
  email         String    @unique
  name          String
  image         String?
  accessToken   String?
  refreshToken  String?
  tokenExpiry   DateTime?
  lastGmailSync DateTime?
  createdAt     DateTime  @default(now())
  isAdmin       Boolean   @default(false)

  systemPrompts SystemPrompt[]
  contextParts  ContextPart[]
  sellingPoints SellingPoint[]
  emailDrafts   EmailDraft[]
  signatures    Signature[]
  budget        UserBudget?

  globalRecords GlobalRecord[]
  recordEvents  RecordEvent[]
  usageEvents   UsageEvent[]

  interactionsCreated    Interaction[]         @relation("InteractionCreator")
  interactionAssignments InteractionAssignee[]
  projectRoles           UserProjectRole[]

  partnerAlignments    PartnerAlignment[]
  outreachDraftsSaved  PartnerOutreachDraft[] @relation("OutreachDraftSavedBy")
  outreachDraftsSent   PartnerOutreachDraft[] @relation("OutreachDraftSentBy")
}

model Group {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  projects      Project[]
  systemPrompts SystemPrompt[]
  contextParts  ContextPart[]
  sellingPoints SellingPoint[]
  emailDrafts   EmailDraft[]
}

model Project {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  systemPrompts      SystemPrompt[]
  contextParts       ContextPart[]
  sellingPoints      SellingPoint[]
  emailDrafts        EmailDraft[]
  interactions       Interaction[]
  projectRoles       ProjectRole[]
  projectRecords     ProjectRecord[]
  partnerAlignments  PartnerAlignment[]
  outreachDrafts     PartnerOutreachDraft[]

  @@unique([groupId, name])
  @@index([groupId])
}

enum BudgetResetPeriod {
  never
  daily
  weekly
  monthly
}

model UserBudget {
  userId        String            @id
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  limitUsd      Float?
  usedUsd       Float             @default(0)
  resetPeriod   BudgetResetPeriod @default(never)
  periodStartAt DateTime? // start of the current billing window
}

model Signature {
  id        String   @id @default(cuid())
  name      String
  content   String
  isDefault Boolean  @default(false)
  isSystem  Boolean  @default(false)
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum StepType {
  MARKET_SCANNING
  PARTNER_IDENTIFICATION
  PARTNER_PROFILING
  VALUE_ALIGNMENT
  OUTREACH_PREPARATION
}

model SystemPrompt {
  id            String         @id @default(cuid())
  name          String
  content       String
  outputSchema  Json?
  stepType      StepType
  isSystem      Boolean        @default(false)
  authorId      String
  author        User           @relation(fields: [authorId], references: [id])
  groupId       String?
  group         Group?         @relation(fields: [groupId], references: [id], onDelete: Restrict)
  projectId     String?
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  derivedFromId String?
  derivedFrom   SystemPrompt?  @relation("PromptLineage", fields: [derivedFromId], references: [id])
  derived       SystemPrompt[] @relation("PromptLineage")
}

model ContextPart {
  id            String        @id @default(cuid())
  name          String
  content       String
  stepKeys      String[]      @default([])
  authorId      String
  author        User          @relation(fields: [authorId], references: [id])
  groupId       String?
  group         Group?        @relation(fields: [groupId], references: [id], onDelete: Restrict)
  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  derivedFromId String?
  derivedFrom   ContextPart?  @relation("ContextLineage", fields: [derivedFromId], references: [id])
  derived       ContextPart[] @relation("ContextLineage")
}

model SellingPoint {
  id            String         @id @default(cuid())
  name          String
  content       String
  authorId      String
  author        User           @relation(fields: [authorId], references: [id])
  groupId       String?
  group         Group?         @relation(fields: [groupId], references: [id], onDelete: Restrict)
  projectId     String?
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  derivedFromId String?
  derivedFrom   SellingPoint?  @relation("SellingLineage", fields: [derivedFromId], references: [id])
  derived       SellingPoint[] @relation("SellingLineage")
}

model EmailDraft {
  id            String         @id @default(cuid())
  name          String
  subject       String
  body          String
  authorId      String
  author        User           @relation(fields: [authorId], references: [id])
  groupId       String?
  group         Group?         @relation(fields: [groupId], references: [id], onDelete: Restrict)
  projectId     String?
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  derivedFromId String?
  derivedFrom   EmailDraft?    @relation("DraftLineage", fields: [derivedFromId], references: [id])
  derived       EmailDraft[]   @relation("DraftLineage")
}

model Partner {
  id             String   @id @default(cuid())
  name           String
  website        String?
  description    String?
  type           String?
  rawData        Json?
  createdAt      DateTime @default(now())
  globalRecordId String?

}

// ── Global Record System ─────────────────────────────────────────────────────

enum RecordType {
  COMPETITION
  PARTNER
  ORGANISATION
  CHANNEL
  SOURCE
  OPPORTUNITY
}

enum AddMethod {
  GENERATED
  IMPORTED
  MANUAL
  GLOBAL_DB
  INHERITED
}

model GlobalRecord {
  id             String         @id @default(cuid())
  type           RecordType
  canonicalName  String
  normalizedName String
  payload        Json
  sourceMetadata Json?
  createdBy      String
  creator        User           @relation(fields: [createdBy], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  duplicateOfId  String?
  duplicateOf    GlobalRecord?  @relation("Duplicates", fields: [duplicateOfId], references: [id])
  duplicates     GlobalRecord[] @relation("Duplicates")

  events            RecordEvent[]
  contacts          PartnerContact[]
  interactions      Interaction[]
  projectRecords    ProjectRecord[]
  partnerAlignments PartnerAlignment[]
  outreachDrafts    PartnerOutreachDraft[]

  @@unique([normalizedName, type])
}

// ── Usage tracking ────────────────────────────────────────────────────────────

enum UsageEventType {
  ai_completion
  serp_search
}

model UsageEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  eventType    UsageEventType
  model        String? // e.g. "anthropic/claude-sonnet-4.6" or "serpapi"
  costUsd      Float          @default(0)
  generationId String? // OpenRouter generation ID for AI calls

  stepType       String? // e.g. "VALUE_ALIGNMENT"

  @@index([userId, createdAt])
  @@index([userId, eventType])
}

// ── System-wide configuration ─────────────────────────────────────────────────

model SystemConfig {
  key       String   @id // e.g. "budget.defaultLimitUsd"
  value     Json // arbitrary JSON value
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model RecordEvent {
  id             String       @id @default(cuid())
  globalRecordId String
  globalRecord   GlobalRecord @relation(fields: [globalRecordId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  eventType      String
  timestamp      DateTime     @default(now())
  metadata       Json?
}

// ── Partner CRM System ────────────────────────────────────────────────────────

enum MailDirection {
  SENT
  RECEIVED
}

model PartnerContact {
  id             String       @id @default(cuid())
  globalRecordId String
  globalRecord   GlobalRecord @relation(fields: [globalRecordId], references: [id], onDelete: Cascade)
  address        String
  label          String?
  firstName      String?
  lastName       String?
  role           String?
  contactType    String?
  priority       Int          @default(3)
  note           String?
  isPrimary      Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@unique([globalRecordId, address])
  @@index([globalRecordId])
}

// ── Interaction System ────────────────────────────────────────────────────────

enum InteractionType {
  NOTE
  EMAIL
  FULFILLMENT
}

enum ActionStatus {
  WAITING_FOR_THEM
  WAITING_FOR_US
  BEFORE_MEETING
  NONE
}

enum DealStage {
  CONTACTED
  NEGOTIATING
  NOT_INTERESTED
  NOT_THIS_TIME
  PARTNER
  COMPLETED
}

model Interaction {
  id             String          @id @default(cuid())
  globalRecordId String
  globalRecord   GlobalRecord    @relation(fields: [globalRecordId], references: [id], onDelete: Cascade)
  projectId      String
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type           InteractionType

  content   String?
  createdBy String
  creator   User     @relation("InteractionCreator", fields: [createdBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // EMAIL-specific
  direction   MailDirection?
  subject     String?
  sentAt      DateTime?
  fromAddress String?
  toAddress   String?
  gmailId     String?

  // FULFILLMENT-specific
  myToThem String?
  themToUs String?

  // Unknown contact detection
  isUnknownContact      Boolean @default(false)
  unknownContactAddress String?

  assignees InteractionAssignee[]

  @@unique([gmailId, globalRecordId])
  @@index([globalRecordId, projectId])
  @@index([globalRecordId])
  @@index([projectId])
}

model InteractionAssignee {
  interactionId String
  interaction   Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  assignedAt    DateTime    @default(now())

  @@id([interactionId, userId])
  @@index([userId])
}

// ── Project Roles ────────────────────────────────────────────────────────────

model ProjectRole {
  id          String            @id @default(cuid())
  projectId   String
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  permissions String[]
  isSystem    Boolean           @default(false)
  users       UserProjectRole[]
  createdAt   DateTime          @default(now())

  @@unique([projectId, name])
  @@index([projectId])
}

model UserProjectRole {
  userId        String
  projectRoleId String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectRole   ProjectRole @relation(fields: [projectRoleId], references: [id], onDelete: Cascade)
  assignedAt    DateTime    @default(now())

  @@id([userId, projectRoleId])
}

// ── Project CRM Records ─────────────────────────────────────────────────────────

model ProjectRecord {
  id             String       @id @default(cuid())
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  globalRecordId String
  globalRecord   GlobalRecord @relation(fields: [globalRecordId], references: [id], onDelete: Cascade)

  // Moved from deprecated PartnerFulfillment
  contactBlacklist Json?
  emailDisplayMode String @default("text")

  @@unique([projectId, globalRecordId])
  @@index([globalRecordId])
}

// ── Standalone Outreach (nezávislé na PipelineRun) ───────────────────────────

// Výsledek analýzy strategické shody (VALUE_ALIGNMENT) pro konkrétního partnera
// v rámci projektu. Nahrazuje ukládání do PipelineStep.outputData.
model PartnerAlignment {
  id              String       @id @default(cuid())
  projectId       String
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  globalRecordId  String
  globalRecord    GlobalRecord @relation(fields: [globalRecordId], references: [id], onDelete: Cascade)
  outputData      Json         // Objekt s výsledkem VALUE_ALIGNMENT pro tohoto partnera
  systemPromptId  String?
  contextPartIds  String[]
  sellingPointId  String?
  profileSnapshot Json?        // Snapshot profilovacích dat použitých jako vstup pro AI
  authorId        String
  author          User         @relation(fields: [authorId], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([projectId, globalRecordId])
  @@index([projectId])
}

// Připravený e-mail (OUTREACH_PREPARATION) pro konkrétního partnera v projektu.
// Nahrazuje ukládání do PipelineStep.outputData / outreach-save.ts logiku.
model PartnerOutreachDraft {
  id             String       @id @default(cuid())
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  globalRecordId String
  globalRecord   GlobalRecord @relation(fields: [globalRecordId], references: [id], onDelete: Cascade)
  toAddress      String       @default("")
  subject        String       @default("")
  body           String       @default("") // HTML
  systemPromptId String?
  emailDraftId   String?
  config         Json? // { signatureId, selectedArgumentIds, contextPartIds, ... }
  savedById      String
  savedBy        User         @relation("OutreachDraftSavedBy", fields: [savedById], references: [id])
  savedAt        DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  sentAt         DateTime?
  sentById       String?
  sentBy         User?        @relation("OutreachDraftSentBy", fields: [sentById], references: [id])
  sendError      String?
  gmailId        String?

  @@unique([projectId, globalRecordId])
  @@index([projectId])
}

