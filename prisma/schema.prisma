generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  googleId      String    @unique
  email         String    @unique
  name          String
  image         String?
  accessToken   String?
  refreshToken  String?
  tokenExpiry   DateTime?
  lastGmailSync DateTime?
  createdAt     DateTime  @default(now())
  lastLoginAt   DateTime?
  isAdmin       Boolean   @default(false)

  systemPrompts SystemPrompt[]
  contextParts  ContextPart[]
  sellingPoints SellingPoint[]
  emailDrafts   EmailDraft[]
  signatures    Signature[]
  budget        UserBudget?

  globalRecords GlobalRecord[]
  recordEvents  RecordEvent[]
  usageEvents   UsageEvent[]

  emailsCreated          Email[]               @relation("EmailCreator")
  notesCreated           Note[]                @relation("NoteCreator")
  emailAssignments       EmailAssignee[]
  noteAssignments        NoteAssignee[]
  fulfillmentAssignments FulfillmentAssignee[]
  projectRoles           UserProjectRole[]

  partnerAlignments           PartnerAlignment[]
  outreachDraftsSaved         PartnerOutreachDraft[] @relation("OutreachDraftSavedBy")
  outreachDraftsSent          PartnerOutreachDraft[] @relation("OutreachDraftSentBy")
  outreachAssignments         OutreachAssignment[]   @relation("OutreachAssignee")
  outreachAssignmentsGiven    OutreachAssignment[]   @relation("OutreachAssignedBy")
  negotiationAssignments      NegotiationAssignee[]  @relation("NegotiationAssignee")
  negotiationAssignmentsGiven NegotiationAssignee[]  @relation("NegotiationAssignedBy")
  scheduledEmails             ScheduledEmail[]
}

model Group {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  projects      Project[]
  systemPrompts SystemPrompt[]
  contextParts  ContextPart[]
  sellingPoints SellingPoint[]
  emailDrafts   EmailDraft[]
  signatures    Signature[]
}

model Project {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  systemPrompts        SystemPrompt[]
  contextParts         ContextPart[]
  sellingPoints        SellingPoint[]
  emailDrafts          EmailDraft[]
  projectRoles         ProjectRole[]
  negotiations         Negotiation[]
  partnerAlignments    PartnerAlignment[]
  outreachDrafts       PartnerOutreachDraft[]
  outreachAssignments  OutreachAssignment[]
  negotiationAssignees NegotiationAssignee[]
  scheduledEmails      ScheduledEmail[]

  @@unique([groupId, name])
  @@index([groupId])
}

enum BudgetResetPeriod {
  never
  daily
  weekly
  monthly
}

model UserBudget {
  userId        String            @id
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  limitUsd      Float?
  usedUsd       Float             @default(0)
  resetPeriod   BudgetResetPeriod @default(never)
  periodStartAt DateTime? // start of the current billing window
}

model Signature {
  id         String   @id @default(cuid())
  name       String
  content    String
  isTemplate Boolean  @default(false)
  groupId    String
  group      Group    @relation(fields: [groupId], references: [id])
  author     User     @relation(fields: [authorId], references: [id])
  authorId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([groupId])
}

enum StepType {
  MARKET_SCANNING
  PARTNER_IDENTIFICATION
  PARTNER_PROFILING
  VALUE_ALIGNMENT
  OUTREACH_PREPARATION
}

model SystemPrompt {
  id            String         @id @default(cuid())
  name          String
  content       String
  outputSchema  Json?
  stepType      StepType
  isSystem      Boolean        @default(false)
  order         Int            @default(0)
  authorId      String
  author        User           @relation(fields: [authorId], references: [id])
  groupId       String?
  group         Group?         @relation(fields: [groupId], references: [id], onDelete: Restrict)
  projectId     String?
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  derivedFromId String?
  derivedFrom   SystemPrompt?  @relation("PromptLineage", fields: [derivedFromId], references: [id])
  derived       SystemPrompt[] @relation("PromptLineage")
}

model ContextPart {
  id            String        @id @default(cuid())
  name          String
  content       String
  stepKeys      String[]      @default([])
  order         Int           @default(0)
  authorId      String
  author        User          @relation(fields: [authorId], references: [id])
  groupId       String?
  group         Group?        @relation(fields: [groupId], references: [id], onDelete: Restrict)
  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  derivedFromId String?
  derivedFrom   ContextPart?  @relation("ContextLineage", fields: [derivedFromId], references: [id])
  derived       ContextPart[] @relation("ContextLineage")
}

model SellingPoint {
  id            String         @id @default(cuid())
  name          String
  content       String
  order         Int            @default(0)
  authorId      String
  author        User           @relation(fields: [authorId], references: [id])
  groupId       String?
  group         Group?         @relation(fields: [groupId], references: [id], onDelete: Restrict)
  projectId     String?
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  derivedFromId String?
  derivedFrom   SellingPoint?  @relation("SellingLineage", fields: [derivedFromId], references: [id])
  derived       SellingPoint[] @relation("SellingLineage")
}

model EmailDraft {
  id            String       @id @default(cuid())
  name          String
  subject       String
  body          String
  order         Int          @default(0)
  authorId      String
  author        User         @relation(fields: [authorId], references: [id])
  groupId       String?
  group         Group?       @relation(fields: [groupId], references: [id], onDelete: Restrict)
  projectId     String?
  project       Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  derivedFromId String?
  derivedFrom   EmailDraft?  @relation("DraftLineage", fields: [derivedFromId], references: [id])
  derived       EmailDraft[] @relation("DraftLineage")
}

model Partner {
  id             String   @id @default(cuid())
  name           String
  website        String?
  description    String?
  type           String?
  rawData        Json?
  createdAt      DateTime @default(now())
  globalRecordId String?
}

// ── Global Record System ─────────────────────────────────────────────────────

enum RecordType {
  COMPETITION
  PARTNER
  ORGANISATION
  CHANNEL
  SOURCE
  OPPORTUNITY
}

enum AddMethod {
  GENERATED
  IMPORTED
  MANUAL
  GLOBAL_DB
  INHERITED
}

model GlobalRecord {
  id             String         @id @default(cuid())
  type           RecordType
  canonicalName  String
  normalizedName String
  payload        Json
  sourceMetadata Json?
  createdBy      String
  creator        User           @relation(fields: [createdBy], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  duplicateOfId  String?
  duplicateOf    GlobalRecord?  @relation("Duplicates", fields: [duplicateOfId], references: [id])
  duplicates     GlobalRecord[] @relation("Duplicates")

  events               RecordEvent[]
  contacts             PartnerContact[]
  negotiations         Negotiation[]
  partnerAlignments    PartnerAlignment[]
  outreachDrafts       PartnerOutreachDraft[]
  outreachAssignments  OutreachAssignment[]
  negotiationAssignees NegotiationAssignee[]
  scheduledEmails      ScheduledEmail[]

  @@unique([normalizedName, type])
}

// ── Usage tracking ────────────────────────────────────────────────────────────

enum UsageEventType {
  ai_completion
  serp_search
}

model UsageEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  eventType    UsageEventType
  model        String? // e.g. "anthropic/claude-sonnet-4.6" or "serpapi"
  costUsd      Float          @default(0)
  generationId String? // OpenRouter generation ID for AI calls

  stepType String? // e.g. "VALUE_ALIGNMENT"

  @@index([userId, createdAt])
  @@index([userId, eventType])
}

// ── System-wide configuration ─────────────────────────────────────────────────

model SystemConfig {
  key       String   @id // e.g. "budget.defaultLimitUsd"
  value     Json // arbitrary JSON value
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model RecordEvent {
  id             String       @id @default(cuid())
  globalRecordId String
  globalRecord   GlobalRecord @relation(fields: [globalRecordId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  eventType      String
  timestamp      DateTime     @default(now())
  metadata       Json?
}

// ── Partner CRM System ────────────────────────────────────────────────────────

enum MailDirection {
  SENT
  RECEIVED
}

model PartnerContact {
  id             String       @id @default(cuid())
  globalRecordId String
  globalRecord   GlobalRecord @relation(fields: [globalRecordId], references: [id], onDelete: Cascade)
  address        String?
  label          String?
  firstName      String?
  lastName       String?
  role           String?
  contactType    String?
  priority       Int          @default(3)
  note           String?
  createdAt      DateTime     @default(now())

  @@unique([globalRecordId, address])
  @@index([globalRecordId])
}

// ── Negotiation: e-maily, poznámky, plnění ────────────────────────────────────

enum NegotiationStatus {
  CONTACTED
  REMINDED
  WAITING_FOR_THEM
  WAITING_FOR_US
  FULFILLING
  THANKS_REMAINING
  COMPLETED
  NOT_INTERESTED
  NOT_THIS_TIME
}

model Email {
  id            String        @id @default(cuid())
  negotiationId String
  negotiation   Negotiation   @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  direction     MailDirection
  subject       String?
  sentAt        DateTime?
  fromAddress   String?
  toAddress     String?
  ccAddress     String?
  gmailId       String?
  content       String?
  createdBy     String
  creator       User          @relation("EmailCreator", fields: [createdBy], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Unknown contact detection
  isUnknownContact      Boolean @default(false)
  unknownContactAddress String?

  assignees EmailAssignee[]

  @@unique([gmailId, negotiationId])
  @@index([negotiationId])
}

model EmailAssignee {
  emailId    String
  email      Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  assignedAt DateTime @default(now())

  @@id([emailId, userId])
  @@index([userId])
}

model Note {
  id            String      @id @default(cuid())
  negotiationId String
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  content       String
  createdBy     String
  creator       User        @relation("NoteCreator", fields: [createdBy], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  assignees NoteAssignee[]

  @@index([negotiationId])
}

model NoteAssignee {
  noteId     String
  note       Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  assignedAt DateTime @default(now())

  @@id([noteId, userId])
  @@index([userId])
}

model FulfillmentAssignee {
  negotiationId String
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  assignedAt    DateTime    @default(now())

  @@id([negotiationId, userId])
  @@index([userId])
}

// ── Project Roles ────────────────────────────────────────────────────────────

model ProjectRole {
  id          String            @id @default(cuid())
  projectId   String
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  permissions String[]
  isSystem    Boolean           @default(false)
  users       UserProjectRole[]
  createdAt   DateTime          @default(now())

  @@unique([projectId, name])
  @@index([projectId])
}

model UserProjectRole {
  userId        String
  projectRoleId String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectRole   ProjectRole @relation(fields: [projectRoleId], references: [id], onDelete: Cascade)
  assignedAt    DateTime    @default(now())

  @@id([userId, projectRoleId])
}

// ── Project CRM Records ─────────────────────────────────────────────────────────

model Negotiation {
  id             String       @id @default(cuid())
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  globalRecordId String
  globalRecord   GlobalRecord @relation(fields: [globalRecordId], references: [id], onDelete: Cascade)

  negotiationStatus NegotiationStatus?
  emailDisplayMode  String             @default("text")
  autoIncludeDomain Boolean? // null = auto-detect from contacts; true/false = explicit user override

  // Obsah plnění – 1:1 s jednáním, prosté sloupce, žádný typový enum
  myToThem String?
  themToUs String?

  additionalAddresses  NegotiationAddress[]
  blacklistedAddresses NegotiationBlacklistedAddress[]
  emails               Email[]
  notes                Note[]
  fulfillmentAssignees FulfillmentAssignee[]

  @@unique([projectId, globalRecordId])
  @@index([globalRecordId])
}

model NegotiationAddress {
  id            String      @id @default(cuid())
  negotiationId String
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  address       String
  createdAt     DateTime    @default(now())

  @@unique([negotiationId, address])
}

model NegotiationBlacklistedAddress {
  id            String      @id @default(cuid())
  negotiationId String
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  address       String
  createdAt     DateTime    @default(now())

  @@unique([negotiationId, address])
}

// ── Standalone Outreach (nezávislé na PipelineRun) ───────────────────────────

// Výsledek analýzy strategické shody (VALUE_ALIGNMENT) pro konkrétního partnera
// v rámci projektu. Nahrazuje ukládání do PipelineStep.outputData.
model PartnerAlignment {
  id              String       @id @default(cuid())
  projectId       String
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  globalRecordId  String
  globalRecord    GlobalRecord @relation(fields: [globalRecordId], references: [id], onDelete: Cascade)
  outputData      Json // Objekt s výsledkem VALUE_ALIGNMENT pro tohoto partnera
  systemPromptId  String?
  contextPartIds  String[]
  sellingPointId  String?
  profileSnapshot Json? // Snapshot profilovacích dat použitých jako vstup pro AI
  authorId        String
  author          User         @relation(fields: [authorId], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([projectId, globalRecordId])
  @@index([projectId])
}

// Připravený e-mail (OUTREACH_PREPARATION) pro konkrétního partnera v projektu.
// Nahrazuje ukládání do PipelineStep.outputData / outreach-save.ts logiku.
model PartnerOutreachDraft {
  id              String       @id @default(cuid())
  projectId       String
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  globalRecordId  String
  globalRecord    GlobalRecord @relation(fields: [globalRecordId], references: [id], onDelete: Cascade)
  toAddress       String       @default("")
  subject         String       @default("")
  body            String       @default("") // HTML
  systemPromptId  String?
  emailDraftId    String?
  config          Json? // { signatureId, selectedArgumentIds, contextPartIds, ... }
  recommendations Json? // string[] – doporučení z OUTREACH_PREPARATION
  savedById       String
  savedBy         User         @relation("OutreachDraftSavedBy", fields: [savedById], references: [id])
  savedAt         DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  sentAt          DateTime?
  sentById        String?
  sentBy          User?        @relation("OutreachDraftSentBy", fields: [sentById], references: [id])
  sendError       String?
  gmailId         String?

  @@unique([projectId, globalRecordId])
  @@index([projectId])
}

// Přiřazení zodpovědnosti za oslovení partnera (outreach workflow) — vždy max. jeden uživatel na partnera v projektu.
model OutreachAssignment {
  id             String       @id @default(cuid())
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  globalRecordId String
  globalRecord   GlobalRecord @relation(fields: [globalRecordId], references: [id], onDelete: Cascade)
  assigneeId     String
  assignee       User         @relation("OutreachAssignee", fields: [assigneeId], references: [id])
  assignedAt     DateTime     @default(now())
  assignedById   String?
  assignedBy     User?        @relation("OutreachAssignedBy", fields: [assignedById], references: [id])

  @@unique([projectId, globalRecordId, assigneeId])
  @@index([projectId])
  @@index([projectId, globalRecordId])
}

// Přiřazení k jednání s partnerem — nezávislé na OutreachAssignment, může jich být více na partnera.
model NegotiationAssignee {
  id             String       @id @default(cuid())
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  globalRecordId String
  globalRecord   GlobalRecord @relation(fields: [globalRecordId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("NegotiationAssignee", fields: [userId], references: [id])
  assignedAt     DateTime     @default(now())
  assignedById   String?
  assignedBy     User?        @relation("NegotiationAssignedBy", fields: [assignedById], references: [id])

  @@unique([projectId, globalRecordId, userId])
  @@index([projectId])
  @@index([projectId, globalRecordId])
}

enum ScheduledEmailStatus {
  PENDING
  SENDING
  SENT
  CANCELLED
  FAILED
}

// E-mail naplánovaný na budoucí datum/čas — odeslán na pozadí pollerem, mimo 20s grace-period undo mechaniku.
model ScheduledEmail {
  id               String               @id @default(cuid())
  projectId        String
  project          Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  globalRecordId   String
  globalRecord     GlobalRecord         @relation(fields: [globalRecordId], references: [id], onDelete: Cascade)
  toAddress        String
  cc               String?
  bcc              String?
  subject          String
  body             String // plné HTML tělo včetně podpisu
  inReplyToGmailId String?
  scheduledFor     DateTime
  status           ScheduledEmailStatus @default(PENDING)
  createdById      String
  createdBy        User                 @relation(fields: [createdById], references: [id])
  createdAt        DateTime             @default(now())
  sentAt           DateTime?
  gmailId          String?
  errorMessage     String?

  @@index([projectId, globalRecordId])
  @@index([status, scheduledFor])
}
