{
  "name": "coldmailer",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "node --max-old-space-size=4096 --disable-warning=DEP0155 ./node_modules/nuxt/bin/nuxt.mjs dev",
    "build": "node --disable-warning=DEP0155 ./node_modules/nuxt/bin/nuxt.mjs build",
    "preview": "node --disable-warning=DEP0155 ./node_modules/nuxt/bin/nuxt.mjs preview",
    "postinstall": "node --disable-warning=DEP0155 ./node_modules/nuxt/bin/nuxt.mjs prepare && prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:migrate-legacy": "bun prisma/migrate-legacy-records.ts"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  },
  "dependencies": {
    "@crawlee/memory-storage": "^3.16.0",
    "@prisma/client": "^5.22.0",
    "@tiptap/extension-color": "^3.23.6",
    "@tiptap/extension-font-family": "^3.23.6",
    "@tiptap/extension-highlight": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/extension-text-align": "^3.23.6",
    "@tiptap/extension-text-style": "^3.23.6",
    "@tiptap/extension-underline": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@tiptap/vue-3": "^3.23.6",
    "@vue-flow/core": "^1.48.2",
    "crawlee": "^3.16.0",
    "nuxt": "^3.14.0",
    "nuxt-auth-utils": "^0.5.7",
    "openai": "^4.77.0",
    "playwright": "^1.59.1",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/tailwindcss": "^6.12.2",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3"
  }
}
