{
  "name": "coldmailer",
  "version": "0.3.4",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "node --max-old-space-size=4096 --disable-warning=DEP0155 ./node_modules/nuxt/bin/nuxt.mjs dev",
    "build": "prisma db seed && node --disable-warning=DEP0155 ./node_modules/nuxt/bin/nuxt.mjs build",
    "preview": "node --disable-warning=DEP0155 ./node_modules/nuxt/bin/nuxt.mjs preview",
    "postinstall": "node --disable-warning=DEP0155 ./node_modules/nuxt/bin/nuxt.mjs prepare && prisma generate",
    "db:push": "prisma db push",
    "db:backfill": "prisma db execute --file scripts/backfill-signature-group-id.sql --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:er-diagram": "bun scripts/generate-er-diagram.ts && bun -e \"const fs=require('fs');fetch('https://kroki.io/mermaid/svg',{method:'POST',headers:{'Content-Type':'text/plain'},body:fs.readFileSync('er-diagram.mmd','utf-8')}).then(r=>r.text()).then(svg=>{fs.writeFileSync('er-diagram.svg',svg);console.log('ER diagram saved to er-diagram.svg')})\""
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@tiptap/extension-highlight": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/extension-text-align": "^3.23.6",
    "@tiptap/extension-text-style": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@tiptap/vue-3": "^3.23.6",
    "dompurify": "^3.4.11",
    "nuxt": "^3.14.0",
    "nuxt-auth-utils": "^0.5.7",
    "openai": "^4.77.0",
    "vue": "^3.5.12"
  },
  "devDependencies": {
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/tailwindcss": "^6.12.2",
    "@types/dompurify": "^3.2.0",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3"
  }
}
